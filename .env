# ─────────────────────────────────────────────────────────────
#  Interview-Trainer- AI — Environment Variables
#  Copy this file to .env and fill in your actual values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# IBM watsonx.ai
WX_API_KEY=
WX_URL=
WX_PROJECT_ID=

# IBM COS
COS_ACCESS_KEY=
COS_SECRET_KEY=
COS_BUCKET_NAME=
COS_REGION=
COS_ENDPOINT=
COS_INSTANCE_ID=


# JWT
JWT_SECRET=change-this-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# MongoDB
MONGODB_URI=

# App
APP_ENV=development
CORS_ORIGIN=http://localhost:5173
